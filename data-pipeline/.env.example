# 이 파일을 복사해서 .env 파일을 만들고 실제 값을 채워주세요.
# cp .env.example .env

# FRED API (https://fred.stlouisfed.org 에서 발급)
FRED_API_KEY=your_fred_api_key_here

# Gemini API (https://aistudio.google.com 에서 발급)
GEMINI_API_KEY=your_gemini_api_key_here

# Tiingo API (https://api.tiingo.com 에서 발급 - 무료, adjusted 포함)
TIINGO_API_KEY=your_tiingo_api_key_here

# Polygon.io API (https://polygon.io 에서 발급 - 무료 Starter 플랜)
POLYGON_API_KEY=your_polygon_api_key_here

# PostgreSQL (docker-compose 기본값과 동일하게 맞춰두면 됩니다)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=hindsight
POSTGRES_USER=hindsight
POSTGRES_PASSWORD=hindsight

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
