# 이 파일을 .env로 복사 후 실제 값을 채우세요.
# cp .env.example .env

# FRED API (https://fred.stlouisfed.org)
FRED_API_KEY=

# Gemini API (https://aistudio.google.com - 무료 1,500 req/day)
GEMINI_API_KEY=
# (선택) 사용할 모델. 기본: gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite

# Alpha Vantage (https://www.alphavantage.co - 25 req/day 무료)
ALPHA_VANTAGE_API_KEY=

# Tiingo (https://api.tiingo.com - 무료, adjusted 가격)
TIINGO_API_KEY=

# The Guardian (https://open-platform.theguardian.com - 무료)
GUARDIAN_API_KEY=

# PostgreSQL (Supabase Session Pooler)
# Supabase 프로젝트의 Database Settings > Connection string > Session pooler 참고
POSTGRES_HOST=aws-1-ap-northeast-2.pooler.supabase.com
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres.<project-ref>
POSTGRES_PASSWORD=<your-supabase-password>
