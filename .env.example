# 이 파일을 복사해서 .env 파일을 만들고 실제 값을 채워주세요.
# cp .env.example .env
#
# 주의: 로컬 Docker DB는 더 이상 쓰지 않습니다. 모든 환경은 Supabase 단일 PostgreSQL에 연결합니다.

# ─── Backend (Spring Boot) 용 ───────────────────────────────
# Supabase Session Pooler 연결 정보
DATABASE_URL=jdbc:postgresql://aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres
DATABASE_USERNAME=postgres.<project-ref>
DATABASE_PASSWORD=<your-supabase-password>

# JWT
JWT_SECRET=hindsight-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256

# Kakao OAuth (https://developers.kakao.com)
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Frontend (Vite) 용 ─────────────────────────────────────
VITE_KAKAO_REST_API_KEY=your_kakao_rest_api_key
VITE_KAKAO_JS_KEY=your_kakao_javascript_key
